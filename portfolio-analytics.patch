+    a.download = `profit-loss-${new Date().toISOString().split('T')[0]}.csv`;
+    a.click();
+    URL.revokeObjectURL(url);
+  };
+
+  return (
+    <div className={`bg-white rounded-lg shadow-lg p-6 ${className}`}>
+      <div className="flex justify-between items-center mb-6">
