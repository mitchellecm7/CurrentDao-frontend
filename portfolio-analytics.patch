+    const typeRows = Object.entries(profitLoss.pnlByAssetType).map(([type, pnl]) => [
+      '',
+      '',
+      type,
+      formatCurrency(pnl)
+    ]);
+
+    const csv = [headers, ...assetRows, ...typeRows].map(row => row.join(',')).join('\n');
